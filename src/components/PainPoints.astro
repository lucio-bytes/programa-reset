---
const pains = [
  {
    title: 'Inchaço Constante',
    desc: 'Acorda bem, mas parece estar grávida no final do dia.',
  },
  {
    title: 'Falta de Energia',
    desc: 'Depende de café para sobreviver e tem quedas de energia à tarde.',
  },
  {
    title: 'Efeito Sanfona',
    desc: 'Já tentou de tudo, perde peso, mas ganha tudo de novo meses depois.',
  },
]
---

<section class="py-20 bg-[#F5EBE6]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">
        Você se identifica com alguma dessas situações?
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {
        pains.map((pain) => (
          <article class="bg-[#FDFBF7] p-8 rounded-2xl shadow-sm border border-[#E8E1DB]">
            <div class="w-12 h-12 bg-[#1A3626]/10 rounded-full flex items-center justify-center mb-6">
              <span class="text-[#1A3626] text-xl font-serif">!</span>
            </div>
            <h3 class="text-xl font-bold mb-3">{pain.title}</h3>
            <p class="text-gray-600">{pain.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
