---
const pains = [
  'Inchaço constante',
  'Distensão abdominal, gases, intestino preso, diarréia, azia',
  'Dificuldade de reduzir o peso',
  'Imunidade baixa',
  'Desejo por doces',
  'Cabelo afinando e caindo / unhas fracas / pele acneica',
  'Dor de cabeça com frequência',
  'Cansaço',
  'Retenção de líquidos',
  'Alterações de humor: ansiedade / irritabilidade',
]
---

<section class="bg-[#F5EBE6] py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-12 max-w-3xl text-center">
      <h2 class="mb-4 font-serif text-2xl font-bold text-gray-900 md:text-4xl">
        O programa <span class="text-[#1A3626]">RESET</span> é para você que tem quaisquer
        das queixas:
      </h2>
    </div>
    <div class="mx-auto grid max-w-4xl gap-3 sm:grid-cols-2">
      {
        pains.map((pain) => (
          <article class="flex items-center gap-3 rounded-xl border border-[#E8E1DB] bg-[#FDFBF7] px-5 py-4">
            <span class="mt-0.5 text-lg text-[#1A3626]">✦</span>
            <p class="text-gray-700">{pain}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
