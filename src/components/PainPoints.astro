---
import { Icon } from 'astro-icon/components'

const pains = [
  'Inchaço constante',
  'Distensão abdominal, gases, intestino preso, diarréia, azia',
  'Dificuldade de reduzir o peso',
  'Imunidade baixa',
  'Desejo por doces',
  'Cabelo afinando e caindo / unhas fracas / pele acneica',
  'Dor de cabeça com frequência',
  'Cansaço',
  'Retenção de líquidos',
  'Alterações de humor: ansiedade / irritabilidade',
]
---

<section class="bg-surface-alt py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-12 max-w-3xl text-center" data-animate>
      <h2 class="mb-4 font-serif text-2xl font-bold text-gray-900 md:text-4xl">
        O programa <span class="text-primary">RESET</span> é para você que tem quaisquer
        das queixas:
      </h2>
    </div>
    <div
      class="mx-auto grid max-w-4xl gap-3 sm:grid-cols-2"
      data-animate-stagger
    >
      {
        pains.map((pain) => (
          <article
            class="border-border bg-surface flex items-center gap-3 rounded-xl border px-5 py-4"
            data-animate
          >
            <Icon
              name="lucide:alert-circle"
              class="text-accent mt-0.5 h-5 w-5 shrink-0"
            />
            <p class="text-gray-700">{pain}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
