---
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata
  alt?: string
}

const { src, alt = 'Foto da profissional' } = Astro.props
---

<div
  class="relative z-10 -mt-28 -mb-28 flex justify-center"
  data-animate="scale"
>
  <div
    class="h-56 w-44 overflow-hidden rounded-2xl shadow-xl ring-4 ring-white md:h-64 md:w-52"
  >
    <img src={src.src} alt={alt} class="h-full w-full object-cover" />
  </div>
</div>
