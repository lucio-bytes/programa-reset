---
import { Icon } from 'astro-icon/components'

const etapas = [
  {
    tag: 'Etapa 1',
    title: 'Remover',
    desc: 'A fase da "faxina interna". A detoxificação será feita por 7 dias, com foco na limpeza dos seus principais órgãos de eliminação: intestino e fígado. Remoção de alérgicos e redução de inflamações.',
    descPlus: '',
  },
  {
    tag: 'Etapa 2',
    title: 'Equilibrar',
    desc: 'Introdução dos alimentos que reestruturam a flora intestinal através do cardápio anti-inflamatório.',
    descPlus: 'Shot intestinal exclusivo do programa para 30 dias.',
  },
]

const bonus = [
  'Guia com receitas para emagrecimento e saúde intestinal',
  'Guia de suplementação',
  'Guia emagrecimento — psicóloga Monique Machado',
  'Planner para autopercepção e controle de hábitos',
]
---

<section class="bg-surface-alt pt-36 pb-36">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-14 max-w-3xl text-center" data-animate>
      <h2 class="mb-4 font-serif text-3xl font-bold text-gray-900 md:text-4xl">
        O que vai receber no Programa <span class="text-primary font-black"
          >RESET</span
        >:
      </h2>
    </div>

    <div
      class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2"
      data-animate-stagger
    >
      {
        etapas.map((etapa) => (
          <article
            class="border-border bg-surface rounded-2xl border p-8"
            data-animate
          >
            <span class="bg-primary mb-2 inline-block rounded-full px-3 py-1 text-xs font-semibold tracking-wider text-white uppercase">
              {etapa.tag}
            </span>
            <h3 class="mb-3 font-serif text-2xl font-bold text-gray-900">
              {etapa.title}
            </h3>
            {etapa.descPlus ? (
              <ul class="mt-1 list-disc space-y-2 pl-5 leading-relaxed text-gray-600">
                <li>{etapa.desc}</li>
                <li>{etapa.descPlus}</li>
              </ul>
            ) : (
              <p class="leading-relaxed text-gray-600">{etapa.desc}</p>
            )}
          </article>
        ))
      }
    </div>

    <div
      class="border-border bg-surface mx-auto mt-10 max-w-4xl rounded-2xl border p-8"
      data-animate
    >
      <h3 class="mb-6 text-center font-serif text-2xl font-bold text-gray-900">
        Bônus
      </h3>
      <div class="grid gap-3 sm:grid-cols-2">
        {
          bonus.map((item) => (
            <div class="flex items-start gap-3">
              <Icon
                name="lucide:circle-check"
                class="text-accent mt-0.5 h-5 w-5 shrink-0"
              />
              <p class="text-gray-700">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
