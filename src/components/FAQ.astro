---
import { Icon } from 'astro-icon/components'

const faqs = [
  {
    q: 'Posso iniciar quando eu quiser?',
    a: 'Sim! Assim que você efetuar a compra, o programa pode ser iniciado quando você estiver preparada.',
  },
  {
    q: 'Quanto tempo dura o programa?',
    a: 'A fase 1 dura 7 dias e a fase 2 pode ser seguida por até 30 dias.',
  },
  {
    q: 'O que fazer após efetuar a compra?',
    a: 'Acesse a plataforma para visualizar os materiais.',
  },
  {
    q: 'Eu terei suporte após a compra?',
    a: 'Sim, qualquer dúvida pode entrar em contato pelo WhatsApp: 51.98352-2637.',
  },
]
---

<section class="bg-surface-alt px-4 py-20 sm:px-6 lg:px-8">
  <h2
    class="mb-12 text-center font-serif text-3xl font-bold text-gray-900"
    data-animate
  >
    Perguntas Frequentes
  </h2>
  <div class="mx-auto max-w-3xl space-y-4" data-animate-stagger>
    {
      faqs.map((faq) => (
        <div
          class="faq-item rounded-xl border border-gray-100 bg-white shadow-sm"
          data-animate
        >
          <button
            class="faq-trigger flex w-full cursor-pointer items-center justify-between gap-1.5 p-6 text-left font-medium text-gray-900"
            aria-expanded="false"
          >
            <h4>{faq.q}</h4>
            <span class="text-primary relative h-5 w-5 shrink-0">
              <Icon
                name="lucide:plus"
                class="faq-icon-plus absolute inset-0 h-5 w-5 transition-all duration-300"
              />
              <Icon
                name="lucide:minus"
                class="faq-icon-minus absolute inset-0 h-5 w-5 opacity-0 transition-all duration-300"
              />
            </span>
          </button>
          <div class="faq-body grid grid-rows-[0fr] transition-[grid-template-rows] duration-350 ease-[cubic-bezier(0.16,1,0.3,1)]">
            <div class="overflow-hidden">
              <p class="px-6 pb-6 leading-relaxed text-gray-600">{faq.a}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import '../scripts/faq.ts'
</script>

<style>
  .faq-item.open .faq-body {
    grid-template-rows: 1fr;
  }
  .faq-item.open .faq-icon-plus {
    opacity: 0;
    transform: rotate(90deg);
  }
  .faq-item.open .faq-icon-minus {
    opacity: 1;
    transform: rotate(0deg);
  }
  .faq-icon-minus {
    transform: rotate(-90deg);
  }
</style>
