---
import Button from './Button.astro'
import profileImg from '../assets/images/profile1.jpg'
---

<section class="hero-section relative min-h-screen overflow-hidden">
  <div
    class="from-surface-dark via-surface-dark-mid to-surface-dark absolute inset-0 bg-linear-to-b"
  >
  </div>

  <div class="pointer-events-none absolute inset-0">
    <div
      class="bg-primary/30 absolute top-1/4 left-1/2 h-[500px] w-[500px] -translate-x-1/2 rounded-full blur-[120px]"
    >
    </div>
    <div
      class="bg-primary/20 absolute right-1/4 bottom-1/4 h-[300px] w-[300px] rounded-full blur-[100px]"
    >
    </div>
  </div>

  <div
    class="relative z-10 mx-auto flex min-h-screen max-w-6xl flex-col items-center justify-center px-4 sm:px-6 lg:px-8"
  >
    <div
      class="flex w-full flex-col items-center gap-8 md:flex-row md:gap-12 lg:gap-16"
    >
      <div
        class="order-2 flex-1 text-center md:order-1 md:text-left"
        data-animate="hero-text"
      >
        <h1
          class="mb-6 font-serif text-4xl leading-[1.1] font-bold tracking-tight text-white sm:text-5xl lg:text-6xl"
        >
          <span class="text-primary-light">RESET</span> — O intestino a favor do seu
          emagrecimento
        </h1>
        <p
          class="mb-8 max-w-lg text-lg leading-relaxed text-gray-300 sm:text-xl"
        >
          28 dias para desinflamar o corpo, destravar o emagrecimento e devolver
          sua energia vital.
        </p>
        <div class="flex flex-col items-center gap-4 md:items-start">
          <Button
            text="GARANTIR MINHA VAGA"
            className="text-primary! rounded-full bg-white! px-10 py-4 text-sm font-bold tracking-wider shadow-xl hover:bg-gray-100!"
          />
        </div>
      </div>

      <div class="order-1 shrink-0 md:order-2" data-animate="hero-image">
        <div
          class="hero-image-wrapper relative h-[420px] w-[340px] rounded-4xl sm:h-[500px] sm:w-[400px] lg:h-[600px] lg:w-[460px]"
        >
          <div class="bg-primary/20 absolute -inset-8 blur-[80px]"></div>
          <img
            src={profileImg.src}
            alt="Fabiana Kirsch - Nutricionista"
            class="relative h-full w-full rounded-4xl object-cover object-top"
          />
        </div>
      </div>
    </div>
  </div>
</section>
