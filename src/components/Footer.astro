---
import { Icon } from 'astro-icon/components'

const year = new Date().getFullYear()
const whatsappNumber = '5551983522637'
const encodedMessage =
  'Ol%C3%A1%21%20Vi%20sua%20p%C3%A1gina%20sobre%20o%20Programa%20Reset%20e%20achei%20incr%C3%ADvel%20a%20proposta%20de%20emagrecimento%2E%20Gostaria%20de%20tirar%20uma%20d%C3%BAvida%20antes%20de%20me%20inscrever%2E%20Pode%20me%20ajudar%3F'

const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodedMessage}`
const instagramUrl = 'https://www.instagram.com/fabikirschnutri/'
---

<footer class="bg-primary py-12 text-white">
  <div
    class="mx-auto flex max-w-7xl flex-col items-center px-4 text-center sm:px-6 lg:px-8"
  >
    <div class="text-surface mb-2 font-serif text-xl font-bold">
      Fabiana Kirsch | Nutricionista
    </div>
    <span class="text-accent mb-2 text-xs tracking-wider uppercase">
      Programa RESET
    </span>
    <p
      class="text-surface/70 mb-6 max-w-md text-center text-sm leading-relaxed"
    >
      O intestino a favor do seu emagrecimento.
    </p>

    <div class="flex gap-4">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-surface/70 mb-8 flex items-center gap-2 text-sm transition-colors hover:text-white"
      >
        <Icon name="lucide:message-circle" class="h-4 w-4" />
        WhatsApp
      </a>

      <a
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-surface/70 mb-8 flex items-center gap-2 text-sm transition-colors hover:text-white"
      >
        <Icon name="lucide:instagram" class="h-4 w-4" />
        Instagram
      </a>
    </div>

    <p class="text-surface/40 text-xs">
      &copy; {year} Fabiana Kirsch. Todos os direitos reservados.
    </p>
    <p class="text-surface/30 mt-1 text-xs">
      Este produto não substitui acompanhamento médico ou nutricional.
    </p>
  </div>
</footer>
